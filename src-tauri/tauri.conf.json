{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aemeath-music",
  "version": "0.1.0",
  "identifier": "com.aemeath.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "aemeath-music",
        "width": 1380,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 850,
        "resizable": true,
        "visible": true
      },
      {
        "label": "mini",
        "title": "aemeath-music mini",
        "width": 380,
        "height": 120,
        "minWidth": 320,
        "minHeight": 100,
        "maxWidth": 480,
        "maxHeight": 200,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Music/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
